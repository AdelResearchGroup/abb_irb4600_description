<?xml version="1.0" encoding="UTF-8"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- RAL 7035 light grey (abb graphite white), standard robot color May 2014 - current -->
  <xacro:property name="color_abb_graphite_white" value="0.7725490 0.7803922 0.7686275 1" />

  <xacro:macro name="material_abb_graphite_white">
    <material name="abb_graphite_white">
      <color rgba="${color_abb_graphite_white}"/>
    </material>
  </xacro:macro>

  <xacro:macro name="abb_irb4600_40_255" params="
    prefix
    parent:=world
    xyz:='0 0 0'
    rpy:='0 0 0'
  ">
    <!-- link list -->
    <link name="${prefix}base_mount"/>

    <link name="${prefix}base_link">
      <inertial>
        <origin xyz="0.0 0.0 0.0"/>
        <mass value="120.00000"/>
        <inertia ixx="1.954" iyy="4.016" izz="5.235" ixy="-0.0016" ixz="-0.231" iyz="0.0008"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://abb_irb4600_description/meshes/visual/base_link.stl"/>
        </geometry>
        <xacro:material_abb_graphite_white />
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://abb_irb4600_description/meshes/collision/base_link.stl"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}link_1">
      <inertial>
        <origin xyz="0.18000 0.00000 0.50000"/>
        <mass value="120.00000"/>
        <inertia ixx="3.238" iyy="3.434" izz="4.066" ixy="-0.946" ixz="-0.052" iyz="0.075"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://abb_irb4600_description/meshes/visual/link_1.stl"/>
        </geometry>
        <xacro:material_abb_graphite_white />
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://abb_irb4600_description/meshes/collision/link_1.stl"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}link_2">
      <inertial>
        <origin xyz="0.94000 0.08000 -0.34000"/>
        <mass value="120.00000"/>
        <inertia ixx="14.820" iyy="0.809" izz="14.484" ixy="0" ixz="-0.0068" iyz="0"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://abb_irb4600_description/meshes/visual/link_2.stl"/>
        </geometry>
        <xacro:material_abb_graphite_white />
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://abb_irb4600_description/meshes/collision/link_2.stl"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}link_3">
      <inertial>
        <origin xyz="0.07000 -0.26600 0.08800"/>
        <mass value="120.00000"/>
        <inertia ixx="3.521" iyy="5.126" izz="4.484" ixy="0.132" ixz="0.051" iyz="-0.067"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://abb_irb4600_description/meshes/visual/link_3.stl"/>
        </geometry>
        <xacro:material_abb_graphite_white />
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://abb_irb4600_description/meshes/collision/link_3.stl"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}link_4">
      <inertial>
        <origin xyz="0.00000 0.00000 1.00000"/>
        <mass value="40.00000"/>
        <inertia ixx="0.193" iyy="3.727" izz="3.765" ixy="-0.012" ixz="0.006" iyz="0.00005"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://abb_irb4600_description/meshes/visual/link_4.stl"/>
        </geometry>
        <xacro:material_abb_graphite_white />
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://abb_irb4600_description/meshes/collision/link_4.stl"/>
        </geometry>
      </collision>
    </link>
    <link name="${prefix}link_5">
      <inertial>
        <origin xyz="0.14000 0.00000 0.00000"/>
        <mass value="10.00000"/>
        <inertia ixx="0.0248" iyy="0.0248" izz="0.0248" ixy="0" ixz="0" iyz="0"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://abb_irb4600_description/meshes/visual/link_5.stl"/>
        </geometry>
        <xacro:material_abb_graphite_white />
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://abb_irb4600_description/meshes/collision/link_5.stl"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}link_6">
      <inertial>
        <origin xyz="0.08100 -0.09100 0.33200"/>
        <mass value="5.00000"/>
        <inertia ixx="0.0130" iyy="0.0130" izz="0.0130" ixy="0" ixz="0" iyz="0"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://abb_irb4600_description/meshes/visual/link_6.stl"/>
        </geometry>
        <xacro:material_abb_graphite_white />
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://abb_irb4600_description/meshes/collision/link_6.stl"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}flange"/>

    <link name="${prefix}tool0"/>
    <!-- end of link list -->

    <!-- joint list -->
    <joint name="${prefix}mount_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}base_mount"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>

    <joint name="${prefix}base_fixed_joint" type="fixed">
      <parent link="${prefix}base_mount"/>
      <child link="${prefix}base_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <joint name="${prefix}joint_1" type="revolute">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}link_1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="${radians(-180)}" upper="${radians(180)}" effort="100000" velocity="${radians(175)}" />
      <dynamics damping="5.0" friction="0.2" />
    </joint>

    <joint name="${prefix}joint_2" type="revolute">
      <parent link="${prefix}link_1"/>
      <child link="${prefix}link_2"/>
      <origin xyz="0.175 0 0.495" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${radians(-90)}" upper="${radians(150)}" effort="100000" velocity="${radians(175)}" />
      <dynamics damping="5.0" friction="0.2" />
    </joint>

    <joint name="${prefix}joint_3" type="revolute">
      <parent link="${prefix}link_2"/>
      <child link="${prefix}link_3"/>
      <origin xyz="0 0 1.095" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${radians(-180)}" upper="${radians(75)}" effort="100000" velocity="${radians(175)}" />
      <dynamics damping="5.0" friction="0.2" />
    </joint>

    <joint name="${prefix}joint_4" type="revolute">
      <parent link="${prefix}link_3"/>
      <child link="${prefix}link_4"/>
      <origin xyz="0.331 0 0.175" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="${radians(-400)}" upper="${radians(400)}" effort="10000" velocity="${radians(250)}" />
      <dynamics damping="5.0" friction="0.2" />
    </joint>

    <joint name="${prefix}joint_5" type="revolute">
      <parent link="${prefix}link_4"/>
      <child link="${prefix}link_5"/>
      <origin xyz="0.939 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${radians(-125)}" upper="${radians(120)}" effort="100000" velocity="${radians(250)}" />
      <dynamics damping="5.0" friction="0.2" />
    </joint>

    <joint name="${prefix}joint_6" type="revolute">
      <parent link="${prefix}link_5"/>
      <child link="${prefix}link_6"/>
      <origin xyz="0.135 0 0" rpy="0 ${pi/2} 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="${radians(-400)}" upper="${radians(400)}" effort="100000" velocity="${radians(360)}" />
      <dynamics damping="5.0" friction="0.2" />
    </joint>

    <joint name="${prefix}joint_6_to_${prefix}flange" type="fixed">
      <parent link="${prefix}link_6"/>
      <child link="${prefix}flange"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <joint name="${prefix}flange_to_${prefix}tool0" type="fixed">
      <parent link="${prefix}flange"/>
      <child link="${prefix}tool0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    <!-- end of joint list -->

  </xacro:macro>
</robot>